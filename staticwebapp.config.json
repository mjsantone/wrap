{
  "routes": [
    {
      "route": "/b/*",
      "rewrite": "/b.html"
    },
    {
      "route": "/library",
      "rewrite": "/library.html"
    },
    {
      "route": "/gallery",
      "redirect": "/library",
      "statusCode": 301
    }
  ],
  "platform": {
    "apiRuntime": "node:20"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff"
  }
}